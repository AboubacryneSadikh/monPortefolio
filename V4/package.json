{
  "name": "portfolio-react-v2",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev":        "vite",
    "build":      "vite build",
    "preview":    "vite preview",
    "server":     "json-server --watch db.json --port 3001",
    "css:watch":  "tailwindcss -i ./src/input.css -o ./src/output.css --watch",
    "css:build":  "tailwindcss -i ./src/input.css -o ./src/output.css",
    "css:minify": "tailwindcss -i ./src/input.css -o ./src/output.css --minify"
  },
  "dependencies": {
    "react":            "^18.2.0",
    "react-dom":        "^18.2.0",
    "react-router-dom": "^6.22.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "json-server":           "^0.17.4",
    "tailwindcss":           "^3.4.1",
    "vite":                  "^5.1.6"
  }
}
