{
  "name": "projet-fil-rouge",
  "version": "1.0.0",
  "description": "Portfolio ASD — Projet Fil Rouge JS",
  "type": "module",
  "scripts": {
    "build:css":  "node_modules/@tailwindcss/cli/dist/index.mjs -i src/css/input.css -o src/css/output.css",
    "watch:css":  "node_modules/@tailwindcss/cli/dist/index.mjs -i src/css/input.css -o src/css/output.css --watch",
    "api":        "node_modules/.bin/json-server db.json --port 3001",
    "dev":        "npx serve . --listen 3000",
    "start":      "npm run build:css && npm run api"
  },
  "devDependencies": {
    "@tailwindcss/cli":   "^4.2.2",
    "@tailwindcss/forms": "^0.5.9",
    "json-server":        "^1.0.0-beta.15",
    "tailwindcss":        "^4.2.2"
  }
}
